  "keyFeatures": [
    "Bilingual storytelling in Spanish and Nahuatl",
    "Audio narration with media playback controls",
    "Interactive map showing story locations",
    "Firebase-based authentication and cloud storage",
    "Offline-capable with Room database",
    "Search and discovery features",
    "Favorites and personal story collections",
    "Community-based story organization"
  ],
  "publicApiSurface": [
    "Story (data class with bilingual content)",
    "StoryRepository (getAllStories, getStoryById, addStory, updateStory, deleteStory)",
    "AuthRepository (signIn, signUp, signOut, currentUser)",
    "FirestoreRepository (CRUD operations, search, favorites)",
    "StorageRepository (uploadImage, uploadAudio, deleteFile)",
    "StoryViewModel (stories flow, selectedStory, loadStoryById)",
    "AuthViewModel (authState, signIn, signUp, signOut)",
    "FavoritesViewModel (favorites flow, addToFavorites, removeFromFavorites)",
    "SearchViewModel (searchResults, search)",
    "AddStoryViewModel (addStory with validation)"
  ]
